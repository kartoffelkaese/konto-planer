{
  "name": "konto-planer",
  "version": "4.9.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H localhost",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3001",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop konto-planer",
    "pm2:restart": "pm2 restart konto-planer",
    "pm2:logs": "pm2 logs konto-planer",
    "pm2:monitor": "pm2 monit konto-planer"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "@hono/node-server": "^1.19.13",
    "eslint": "10.4.0"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.29",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "10.4.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
