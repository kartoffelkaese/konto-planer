// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

enum AccountMemberRole {
  OWNER
  MEMBER
  READ_ONLY
}

enum AccountInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum EmailVerificationPurpose {
  SIGNUP
  EMAIL_CHANGE
}

enum SplitListStatus {
  ACTIVE
  ARCHIVED
}

enum SplitListRole {
  OWNER
  MEMBER
}

enum SplitInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  emailVerified           DateTime?
  pendingEmail            String?
  splitDisplayName        String?
  createdAt               DateTime                 @default(now())
  memberships             AccountMember[]
  invitesSent             AccountInvite[]          @relation("InvitedBy")
  emailVerificationTokens EmailVerificationToken[]
  splitListsCreated       SplitList[]              @relation("SplitListsCreated")
  splitListMemberships    SplitListMember[]
  splitParticipants       SplitParticipant[]
  splitExpensesCreated    SplitExpense[]
  splitSettlements        SplitSettlement[]
  splitInvitesSent        SplitListInvite[]        @relation("SplitInvitesSent")

  @@map("users")
}

model EmailVerificationToken {
  id        String                   @id @default(uuid())
  userId    String
  purpose   EmailVerificationPurpose
  tokenHash String                   @unique
  newEmail  String?
  expiresAt DateTime
  createdAt DateTime                 @default(now())
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model Account {
  id                 String          @id @default(uuid())
  name               String
  salaryDay          Int
  transferSenderName String?
  bankId             String?
  isSimpleAccount    Boolean         @default(false)
  createdAt          DateTime        @default(now())
  members         AccountMember[]
  invites         AccountInvite[]
  transactions    Transaction[]
  merchants       Merchant[]
  categories      Category[]
  transferTargets Transaction[]   @relation("TransferTargets")
  transferPairs   TransferPair[]

  @@map("accounts")
}

model AccountMember {
  id        String            @id @default(uuid())
  accountId String
  userId    String
  role      AccountMemberRole
  createdAt DateTime          @default(now())
  account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("account_members")
}

model AccountInvite {
  id              String              @id @default(uuid())
  accountId       String
  email           String
  invitedByUserId String
  role            AccountMemberRole   @default(MEMBER)
  status          AccountInviteStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  account         Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invitedBy       User                @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
  @@map("account_invites")
}

model Transaction {
  id                      String        @id @default(uuid())
  accountId               String
  description             String?
  merchant                String
  merchantId              String?
  merchantRef             Merchant?     @relation(fields: [merchantId], references: [id])
  categoryId              String?
  categoryRef             Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount                  Decimal       @db.Decimal(10, 2)
  date                    DateTime
  isConfirmed             Boolean       @default(false)
  isRecurring             Boolean       @default(false)
  isRecurringPaused       Boolean       @default(false)
  recurringInterval       String?
  lastConfirmedDate       DateTime?
  version                 Int           @default(1)
  parentTransactionId     String?
  parentTransaction       Transaction?  @relation("RecurringInstances", fields: [parentTransactionId], references: [id])
  childTransactions       Transaction[] @relation("RecurringInstances")
  isTransfer              Boolean       @default(false)
  transferTargetAccountId String?
  transferTargetMerchant  String?
  transferTargetAccount   Account?      @relation("TransferTargets", fields: [transferTargetAccountId], references: [id], onDelete: SetNull)
  transferPairAsSource    TransferPair? @relation("TransferSource")
  transferPairAsTarget    TransferPair? @relation("TransferTarget")
  createdAt               DateTime      @default(now())
  account                 Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model TransferPair {
  id                  String       @id @default(uuid())
  sourceTransactionId String       @unique
  targetTransactionId String?      @unique
  targetAccountId     String?
  sourceTransaction   Transaction  @relation("TransferSource", fields: [sourceTransactionId], references: [id], onDelete: Cascade)
  targetTransaction   Transaction? @relation("TransferTarget", fields: [targetTransactionId], references: [id], onDelete: SetNull)
  targetAccount       Account?     @relation(fields: [targetAccountId], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now())

  @@map("transfer_pairs")
}

model Merchant {
  id           String             @id @default(uuid())
  accountId    String
  name         String
  createdAt    DateTime           @default(now())
  account      Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categories   MerchantCategory[]
  transactions Transaction[]

  @@unique([accountId, name])
  @@map("merchants")
}

model MerchantCategory {
  merchantId String
  categoryId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([merchantId, categoryId])
  @@index([categoryId])
  @@map("merchant_categories")
}

model Category {
  id           String             @id @default(uuid())
  accountId    String
  name         String
  color        String             @default("#A7C7E7")
  createdAt    DateTime           @default(now())
  account      Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchants    MerchantCategory[]
  transactions Transaction[]

  @@unique([accountId, name])
  @@map("categories")
}

model SplitList {
  id           String            @id @default(uuid())
  name         String
  description  String?
  status       SplitListStatus   @default(ACTIVE)
  createdById  String
  createdAt    DateTime          @default(now())
  archivedAt   DateTime?
  createdBy    User              @relation("SplitListsCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members      SplitListMember[]
  participants SplitParticipant[]
  categories   SplitCategory[]
  expenses     SplitExpense[]
  settlements  SplitSettlement[]
  invites      SplitListInvite[]

  @@map("split_lists")
}

model SplitListMember {
  id          String        @id @default(uuid())
  splitListId String
  userId      String
  role        SplitListRole
  createdAt   DateTime      @default(now())
  splitList   SplitList     @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([splitListId, userId])
  @@map("split_list_members")
}

model SplitParticipant {
  id              String              @id @default(uuid())
  splitListId     String
  displayName     String
  userId          String?
  sortOrder       Int?
  createdAt       DateTime            @default(now())
  splitList       SplitList           @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  expensesPaid    SplitExpense[]      @relation("ExpensePaidBy")
  expenseShares   SplitExpenseShare[]
  settlementsFrom SplitSettlement[]   @relation("SettlementFrom")
  settlementsTo   SplitSettlement[]   @relation("SettlementTo")
  invites         SplitListInvite[]

  @@unique([splitListId, displayName])
  @@map("split_participants")
}

model SplitCategory {
  id          String         @id @default(uuid())
  splitListId String
  name        String
  color       String?
  sortOrder   Int?
  createdAt   DateTime       @default(now())
  splitList   SplitList      @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  expenses    SplitExpense[]

  @@unique([splitListId, name])
  @@map("split_categories")
}

model SplitExpense {
  id                  String              @id @default(uuid())
  splitListId         String
  paidByParticipantId String
  categoryId          String?
  amount              Decimal             @db.Decimal(10, 2)
  description         String
  date                DateTime
  createdById         String
  createdAt           DateTime            @default(now())
  splitList           SplitList           @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  paidBy              SplitParticipant    @relation("ExpensePaidBy", fields: [paidByParticipantId], references: [id], onDelete: Restrict)
  category            SplitCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy           User                @relation(fields: [createdById], references: [id], onDelete: Cascade)
  shares              SplitExpenseShare[]

  @@map("split_expenses")
}

model SplitExpenseShare {
  expenseId     String
  participantId String
  expense       SplitExpense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  participant   SplitParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@id([expenseId, participantId])
  @@map("split_expense_shares")
}

model SplitSettlement {
  id                String           @id @default(uuid())
  splitListId       String
  fromParticipantId String
  toParticipantId   String
  amount            Decimal          @db.Decimal(10, 2)
  settledAt         DateTime
  settledById       String
  note              String?
  createdAt         DateTime         @default(now())
  splitList         SplitList        @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  fromParticipant   SplitParticipant @relation("SettlementFrom", fields: [fromParticipantId], references: [id], onDelete: Restrict)
  toParticipant     SplitParticipant @relation("SettlementTo", fields: [toParticipantId], references: [id], onDelete: Restrict)
  settledBy         User             @relation(fields: [settledById], references: [id], onDelete: Cascade)

  @@map("split_settlements")
}

model SplitListInvite {
  id              String            @id @default(uuid())
  splitListId     String
  email           String
  participantId   String?
  invitedByUserId String
  status          SplitInviteStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  splitList       SplitList         @relation(fields: [splitListId], references: [id], onDelete: Cascade)
  participant     SplitParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  invitedBy       User              @relation("SplitInvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([splitListId, email])
  @@map("split_list_invites")
}
