// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

enum AccountMemberRole {
  OWNER
  MEMBER
}

enum AccountInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  createdAt     DateTime        @default(now())
  memberships   AccountMember[]
  invitesSent   AccountInvite[] @relation("InvitedBy")

  @@map("users")
}

model Account {
  id           String          @id @default(uuid())
  name         String
  salaryDay    Int
  createdAt    DateTime        @default(now())
  members      AccountMember[]
  invites      AccountInvite[]
  transactions Transaction[]
  merchants    Merchant[]
  categories   Category[]

  @@map("accounts")
}

model AccountMember {
  id        String            @id @default(uuid())
  accountId String
  userId    String
  role      AccountMemberRole
  createdAt DateTime          @default(now())
  account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("account_members")
}

model AccountInvite {
  id              String              @id @default(uuid())
  accountId       String
  email           String
  invitedByUserId String
  status          AccountInviteStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  account         Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invitedBy       User                @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([accountId, email])
  @@map("account_invites")
}

model Transaction {
  id                  String        @id @default(uuid())
  accountId           String
  description         String?
  merchant            String
  merchantId          String?
  merchantRef         Merchant?     @relation(fields: [merchantId], references: [id])
  amount              Decimal       @db.Decimal(10, 2)
  date                DateTime
  isConfirmed         Boolean       @default(false)
  isRecurring         Boolean       @default(false)
  isRecurringPaused   Boolean       @default(false)
  recurringInterval   String?
  lastConfirmedDate   DateTime?
  version             Int           @default(1)
  parentTransactionId String?
  parentTransaction   Transaction?  @relation("RecurringInstances", fields: [parentTransactionId], references: [id])
  childTransactions   Transaction[] @relation("RecurringInstances")
  createdAt           DateTime      @default(now())
  account             Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Merchant {
  id           String        @id @default(uuid())
  accountId    String
  name         String
  categoryId   String?
  category     Category?     @relation(fields: [categoryId], references: [id])
  createdAt    DateTime      @default(now())
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([accountId, name])
  @@map("merchants")
}

model Category {
  id        String     @id @default(uuid())
  accountId String
  name      String
  color     String     @default("#A7C7E7")
  createdAt DateTime   @default(now())
  account   Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  merchants Merchant[]

  @@unique([accountId, name])
  @@map("categories")
}
